{
  "name": "cjdic2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:desktop": "cross-env RUST_BACKTRACE=1 tauri dev",
    "dev:mobile": "cross-env RUST_BACKTRACE=1 tauri dev -c src-tauri/tauri.mobile.conf.json",
    "dev:android": "cross-env RUST_BACKTRACE=1 tauri android run",
    "dev:android:server": "cross-env RUST_BACKTRACE=1 tauri android dev",
    "dev:android:install": "adb install -r src-tauri/gen/android/app/build/outputs/apk/arm64/debug/app-arm64-debug.apk",
    "dev:android:build": "tauri android build --debug",
    "dev:android:log": "adb logcat -e \"RustStdoutStderr\"",
    "build:desktop": "tauri build",
    "build:android": "tauri android build",
    "install:android": "adb install -r src-tauri/gen/android/app/build/outputs/apk/universal/release/app-universal-release.apk",
    "run:desktop": ".\\target\\release\\cjdic2.exe",
    "release": "node release.js",
    "dev": "cd src-react && pnpm run dev",
    "build": "cd src-react && pnpm run build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "cross-env": "^10.1.0",
    "sharp": "^0.34.5"
  }
}
