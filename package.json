    "flutter:frb_codegen": "flutter_rust_bridge_codegen generate",
    "dev": "pnpm run -C src-react dev",
    "build": "pnpm run -C src-react build",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
