{
  "name": "cjdic2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:desktop": "tauri dev",
    "dev:mobile": "tauri dev -c src-tauri/tauri.mobile.conf.json",
    "dev:android": "tauri android dev",
    "build:desktop": "tauri build",
    "build:android": "tauri android build --debug",
    "install:android": "adb install -r src-tauri/gen/android/app/build/outputs/apk/universal/debug/app-universal-debug.apk",
