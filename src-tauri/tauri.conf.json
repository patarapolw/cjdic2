{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cjdic2",
  "version": "0.1.2",
  "identifier": "cc.polv.cjdic2",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../src-react/dist"
  },
  "app": {
    "windows": [
      {
        "title": "cjdic2",
        "width": 1024,
        "height": 768,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/yomitan/**"]
      }
    }
  },
  "bundle": {
    "resources": [
      "resources/mecab-ipadic/system.dic.zst"
    ],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
