{
  "editor.tabSize": 2,
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.formatOnSave": true
  },
  "[rust]": {
    "editor.tabSize": 4,
    "editor.formatOnSave": true
  },
  "cmake.ignoreCMakeListsMissing": true,
  "code-runner.executorMap": {
    "typescript": "tsx"
  }
}
